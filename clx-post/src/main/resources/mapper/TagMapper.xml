<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clx.post.mapper.TagMapper">

    <resultMap id="TagResultMap" type="com.clx.post.entity.Tag">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="color" property="color"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAll" resultMap="TagResultMap">
        SELECT id, name, description, color
        FROM tag
        WHERE is_deleted = 0
        ORDER BY id ASC
    </select>

    <select id="selectById" resultMap="TagResultMap">
        SELECT id, name, description, color
        FROM tag
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <select id="selectByPostId" resultMap="TagResultMap">
        SELECT t.id, t.name, t.description, t.color
        FROM tag t
        INNER JOIN post_tag pt ON t.id = pt.tag_id
        WHERE pt.post_id = #{postId} AND t.is_deleted = 0
    </select>

</mapper>