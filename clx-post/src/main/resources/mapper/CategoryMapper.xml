<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clx.post.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.clx.post.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="code" property="code"/>
        <result column="description" property="description"/>
        <result column="icon" property="icon"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectAll" resultMap="CategoryResultMap">
        SELECT id, name, code, description, icon, sort, status
        FROM category
        WHERE is_deleted = 0 AND status = '0'
        ORDER BY sort ASC
    </select>

    <select id="selectById" resultMap="CategoryResultMap">
        SELECT id, name, code, description, icon, sort, status
        FROM category
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <select id="selectByCode" resultMap="CategoryResultMap">
        SELECT id, name, code, description, icon, sort, status
        FROM category
        WHERE code = #{code} AND is_deleted = 0
    </select>

</mapper>