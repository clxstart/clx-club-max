<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clx.quiz.mapper.SubjectMappingMapper">

    <resultMap id="MappingResultMap" type="com.clx.quiz.entity.SubjectMapping">
        <id column="id" property="id"/>
        <result column="subject_id" property="subjectId"/>
        <result column="category_id" property="categoryId"/>
        <result column="label_id" property="labelId"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <insert id="batchInsert">
        INSERT INTO subject_mapping (subject_id, category_id, label_id, created_by)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.subjectId}, #{item.categoryId}, #{item.labelId}, #{item.createdBy})
        </foreach>
    </insert>

    <select id="selectBySubjectId" resultMap="MappingResultMap">
        SELECT * FROM subject_mapping
        WHERE subject_id = #{subjectId} AND is_deleted = 0
    </select>

    <update id="deleteBySubjectId">
        UPDATE subject_mapping SET is_deleted = 1 WHERE subject_id = #{subjectId}
    </update>

</mapper>